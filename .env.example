ENV=local
LOG_LEVEL=debug

# Database connection parameters (for local Go application)
DB_HOST=localhost
DB_PORT=5432
DB_USER=demogo
DB_PASS=demogo
DB_NAME=demogo
DB_URL_MIGRATE=postgres://demogo:demogo@db:5432/demogo?sslmode=disable
# Database pool settings
DB_MAX_CONNECTIONS=10
DB_MIN_CONNECTIONS=2
DB_MAX_CONNECTION_LIFETIME_MINUTES=60
DB_MAX_CONNECTION_IDLE_TIME_MINUTES=10

SERVER_HTTP_ADDR=localhost:8081
SERVER_HTTP_READ_TIMEOUT_SECONDS=10
SERVER_HTTP_WRITE_TIMEOUT_SECONDS=10

SERVER_GRPC_ADDR=localhost:50051

# Logger
LOG_LEVEL=debug

# Message broker
RABBITMQ_USER=guest
RABBITMQ_PASS=guest
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_EXCHANGE=api.events
RABBITMQ_RECONNECT_DELAY_IN_SECONDS=3

MAIL_DRIVER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USER=
MAIL_PASSWORD=
MAIL_ENCRYPTION=null

APIFY_TOKEN=

TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_DEBUG=false
TELEGRAM_BOT_TIMEOUT=60

# APIFY
APIFY_HOST=https://api.apify.com/v2
APIFY_TOKEN=
APIFY_YOUTUBE_MAX_VIDEOS=5
APIFY_YOUTUBE_DAYS=10
APIFY_TIKTOK_MAX_VIDEOS=5
APIFY_TIKTOK_DAYS=10
APIFY_INSTAGRAM_MAX_VIDEOS=5
APIFY_INSTAGRAM_DAYS=10


# анализ видео
ASSEMBLYAI_TOKEN=ab77c2426ee54c3da84767109a941c41
ASSEMBLYAI_HOST=https://www.assemblyai.com